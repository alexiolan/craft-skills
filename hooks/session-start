#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILL_FILE="$PLUGIN_DIR/skills/bootstrap/SKILL.md"
SCRIPTS_DIR="$PLUGIN_DIR/scripts"

if [ -f "$SKILL_FILE" ]; then
  CONTENT=$(cat "$SKILL_FILE")
  CONTENT="$CONTENT

## Plugin Paths

craft-skills scripts directory: \`$SCRIPTS_DIR\`

When any skill references LLM scripts (llm-agent.sh, llm-review.sh, llm-analyze.sh, llm-check.sh, llm-unload.sh), use this full path. Example: \`bash $SCRIPTS_DIR/llm-agent.sh \"task\" /project/root\`"
  CONTENT=$(echo "$CONTENT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')
  echo "{\"additionalContext\": $CONTENT}"
else
  echo "{}"
fi
