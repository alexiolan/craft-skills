#!/bin/bash

# Auto-create a git tag matching the version after each commit

PACKAGE_JSON="package.json"

VERSION=$(grep -o '"version": "[^"]*"' "$PACKAGE_JSON" | head -1 | grep -o '[0-9]*\.[0-9]*\.[0-9]*')

if [ -z "$VERSION" ]; then
  exit 0
fi

TAG="v$VERSION"

# Only create tag if it doesn't already exist
if ! git tag -l "$TAG" | grep -q "$TAG"; then
  git tag "$TAG"
  echo "Tag created: $TAG"

  # Create GitHub release if gh is available and remote exists
  if command -v gh &> /dev/null && git remote get-url origin &> /dev/null; then
    COMMIT_MSG=$(git log -1 --pretty=%s)
    gh release create "$TAG" --title "$TAG" --notes "$COMMIT_MSG" &> /dev/null && echo "GitHub release created: $TAG" || true
  fi
fi
