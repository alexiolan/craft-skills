#!/bin/bash

# Auto-create a git tag and GitHub release matching the version after each commit
# ONLY on the main branch — feature-branch commits don't create tags or releases.
# Tags + releases are created when a PR is merged into main (which triggers a commit on main here).

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ]; then
  exit 0
fi

PACKAGE_JSON="package.json"

VERSION=$(grep -o '"version": "[^"]*"' "$PACKAGE_JSON" | head -1 | grep -o '[0-9]*\.[0-9]*\.[0-9]*')

if [ -z "$VERSION" ]; then
  exit 0
fi

TAG="v$VERSION"

# Only create tag if it doesn't already exist
if ! git tag -l "$TAG" | grep -q "$TAG"; then
  git tag "$TAG"
  echo "Tag created: $TAG"

  # Push tag and create GitHub release if gh is available and remote exists
  if command -v gh &> /dev/null && git remote get-url origin &> /dev/null; then
    git push origin "$TAG" &> /dev/null && echo "Tag pushed: $TAG" || true
    COMMIT_MSG=$(git log -1 --pretty=%s)
    gh release create "$TAG" --title "$TAG" --notes "$COMMIT_MSG" &> /dev/null && echo "GitHub release created: $TAG" || true
  fi
fi
